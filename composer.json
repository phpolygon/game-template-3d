{
    "name": "phpolygon/game-template-3d",
    "description": "PHPolygon 3D Game Template — Procedural Playground starter project",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "phpolygon/phpolygon": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "D:/PhpstormProjects/phpolygon/phpolygon", "options": { "symlink": true } }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
